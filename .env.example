# Site
SITE_URL=http://localhost:5173
VITE_API_BASE=

# Access tokens (generate: openssl rand -base64 32)
ACCESS_TOKEN_SECRET=change-me-in-production
ACCESS_TOKEN_TTL_DAYS=365

# Beta access (skip Stripe during development)
BETA_ACCESS_CODE=agent-beta

# Stripe — Naval/FAM Checkout wiring (https://dashboard.stripe.com)
# USD hub access only. $AI reward coin stays on Slyk ledger.
STRIPE_SECRET_KEY=sk_test_...
# Prefer STRIPE_PRICE_HUB_ACCESS (from: npm run stripe:setup)
STRIPE_PRICE_HUB_ACCESS=price_...
# Alias still accepted:
# STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Optional one-click Payment Link (buy.stripe.com) — FAM pattern
# STRIPE_LINK_HUB_ACCESS=https://buy.stripe.com/...
# Hub access list price in cents for stripe:setup (default 9900 = $99)
# HUB_ACCESS_PRICE_CENTS=9900

# Upside compliance notifications (Slack/Zapier webhook)
UPSIDE_COMPLIANCE_WEBHOOK_URL=

# CORS
ALLOWED_ORIGIN=*

# MCP server (mcp-server/)
SLYK_API_KEY=
UPSIDE_ACCESS_TOKEN=
UPSIDE_SITE_URL=http://localhost:5173

{
  "name": "ai-agent-upside-hubs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx --env-file=.env server/dev.ts",
    "dev:full": "npx concurrently -k \"vite\" \"tsx --env-file=.env server/dev.ts\"",
    "build": "tsc -b && vite build",
    "build:mcp": "cd mcp-server && npm install && npm run build",
    "stripe:setup": "node scripts/stripe-setup.mjs",
    "lint": "oxlint",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "jose": "^6.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "stripe": "^17.7.0",
    "tailwindcss": "^4.3.2"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.1.14",
    "concurrently": "^9.1.2",
    "express": "^4.21.2",
    "tsx": "^4.19.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.1"
  }
}
